<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 主视频视图 (显示CameraHelper本地预览) -->
    <TextureView
        android:id="@+id/mainVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />



    <!-- 用户列表抽屉 -->
    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- 主内容区域 - 包含小窗口和按钮 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 小窗口容器 - 添加点击效果 -->
            <FrameLayout
                android:id="@+id/smallVideoContainer"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="28dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/small_window_background"
                android:clickable="true"
                android:elevation="8dp"
                android:focusable="true"
                android:visibility="visible">

                <TextureView
                    android:id="@+id/smallVideoView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

            <LinearLayout
                android:id="@+id/liveStatusPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginStart="@dimen/dp_12"
                android:layout_marginTop="@dimen/dp_12"
                android:layout_marginEnd="@dimen/dp_12"
                android:background="@drawable/logs"
                android:orientation="vertical"
                android:padding="@dimen/dp_8">

                <TextView
                    android:id="@+id/tvFragmentUUID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dp_4"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_13"
                    tools:ignore="RelativeOverlap" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@id/bottomButtonContainer"
                android:layout_alignParentStart="true"
                android:layout_marginLeft="@dimen/dp_15"
                android:layout_marginRight="@dimen/dp_15"
                android:layout_marginBottom="@dimen/dp_15"
                android:background="@drawable/logs"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/dp_8"
                    android:paddingTop="@dimen/dp_8"
                    android:paddingEnd="@dimen/dp_8"
                    android:text="会话日志"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_13"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_200"
                    android:layout_marginStart="@dimen/dp_8"
                    android:layout_marginTop="@dimen/dp_4"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:alpha="0.45"
                    android:background="@android:color/transparent"
                    android:padding="@dimen/dp_4"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_13" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_10" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_45"
                    android:layout_marginStart="@dimen/dp_8"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:layout_marginBottom="@dimen/dp_8">

                    <EditText
                        android:id="@+id/et_msg"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="match_parent"
                        android:layout_marginRight="@dimen/dp_10"
                        android:layout_weight="1"
                        android:background="@drawable/tv_bg"
                        android:hint="请输入设备要上报的信息"
                        android:paddingStart="@dimen/dp_10"
                        android:paddingEnd="@dimen/dp_10"
                        android:textColor="@color/color_ccc"
                        android:textColorHint="#CCCCCC"
                        android:textSize="@dimen/sp_15" />

                    <TextView
                        android:id="@+id/send_msg"
                        android:layout_width="@dimen/dp_70"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_background"
                        android:gravity="center"
                        android:text="上报"
                        android:textColor="@color/white"
                        android:textSize="@dimen/dp_14" />
                </LinearLayout>


            </LinearLayout>
            <!-- 底部按钮容器 - 修复定位问题 -->
            <LinearLayout
                android:id="@+id/bottomButtonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- 抽屉按钮 -->
                <ImageButton
                    android:id="@+id/drawerButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="32dp"
                    android:background="@drawable/ic_drawer_background"
                    android:contentDescription="@string/open_rtc_user_label"
                    android:elevation="8dp"
                    android:src="@drawable/ic_menu" />

                <!-- 关闭通话按钮 -->
                <ImageButton
                    android:id="@+id/endCallButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="32dp"
                    android:background="@drawable/ic_drawer_red_background"
                    android:contentDescription="@string/close_rtc_label"
                    android:drawableTint="@android:color/white"
                    android:elevation="8dp"
                    android:src="@drawable/ic_white_call" />

                <!-- 切换摄像头按钮 -->
                <ImageButton
                    android:id="@+id/switchCameraButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/ic_drawer_background"
                    android:contentDescription="@string/change_camera"
                    android:elevation="8dp"
                    android:src="@drawable/ic_switch_camera" />

            </LinearLayout>

        </RelativeLayout>

        <!-- 抽屉内容 -->
        <LinearLayout
            android:id="@+id/drawerContent"
            android:layout_width="210dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@android:color/white"
            android:elevation="16dp"
            android:orientation="vertical">

            <!-- 抽屉标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/b_n_active"
                android:padding="16dp"
                android:text="@string/rtc_user_label"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 用户列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/userRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />

            <!-- 空状态提示 -->
            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:text="@string/rtc_user_online_empty"
                android:textColor="@android:color/darker_gray"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>


    </androidx.drawerlayout.widget.DrawerLayout>

</RelativeLayout>
